<%- include("../header"); %>
<div class="col-12">
    <h1>Agregar Clientes</h1>
    <form method="post" action="/clientes/insertar">

        <div class="form-group">
            <label for="cedula">Cedula</label>
            <input required id="cedula" placeholder="Cedula de Identidad" class="form-control" type="number" name="cedula">
        </div>

        <div class="form-group">
            <label for="nombre">Nombre</label>
            <input required id="nombre" placeholder="Nombre del Cliente" class="form-control" type="text" name="nombre">
        </div>

        <div class="form-group">
            <label for="apellido">Apellido</label>
            <input required id="apellido" placeholder="Apellido del Cliente" class="form-control" type="text" name="apellido">
        </div>

        <div class="form-group">
            <label for="Direccion">Direcci&oacute;n</label>
            <input required id="direccion" placeholder="Direccion del Cliente" class="form-control" type="text" name="direccion">
        </div>

        <div class="form-group">
            <label for="Telefono">Telefono</label>
            <input required id="telefono" placeholder="Telefono del Cliente" class="form-control" type="number" name="telefono">
        </div>

        <div class="form-group">
            <button class="btn btn-success">Guardar</button>
            &nbsp;<a href="/clientes" class="btn btn-primary">Volver</a>
        </div>

    </form>
</div>
<%- include("../footer"); %>