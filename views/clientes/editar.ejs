<%- include("../header"); %>
<div class="col-12">
    <h1>Editar Cliente</h1>
    <form method="post" action="/clientes/actualizar">

        <input value="<%= clientes.id %>" name="id" type="hidden">

        <div class="form-group">
            <label for="cedula">Cedula</label>
            <input value="<%= clientes.cedula %>" required id="cedula" placeholder="cedula del cliente"
                class="form-control" type="number" name="cedula">
        </div>

        <div class="form-group">
            <label for="nombre">Nombre</label>
            <input value="<%= clientes.nombre %>" required id="nombre" placeholder="Nombre del Cliente"
                class="form-control" type="text" name="nombre">
        </div>

        <div class="form-group">
            <label for="Apellido">Apellido</label>
            <input value="<%= clientes.apellido %>" required id="apellido" placeholder="Apellido del Cliente"
                class="form-control" type="text" name="apellido">
        </div>

        <div class="form-group">
            <label for="Direccion">Direcci&oacute;n</label>
            <input value="<%= clientes.direccion %>" required id="direccion" placeholder="Direccion del Cliente"
                class="form-control" type="text" name="direccion">
        </div>

        <div class="form-group">
            <label for="Telefono">Telefono</label>
            <input value="<%= clientes.telefono %>" required id="telefono" placeholder="Telefono del Cliente"
                class="form-control" type="text" name="telefono">
        </div>

        <div class="form-group">
            <button class="btn btn-success">Guardar</button>
            &nbsp;<a href="/clientes" class="btn btn-primary">Volver</a>
        </div>
    </form>
</div>
<%- include("../footer"); %>