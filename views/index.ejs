<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Rhierro 5K - Registro Agropecuario y Control de Hierros</title>
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&family=JetBrains+Mono:ital,wght@0,300..800;1,300..800&display=swap" rel="stylesheet">
  <!-- CSS Principal -->
  <link rel="stylesheet" href="css/style.css">
</head>
<body>

  <!-- Barra de Navegación Premium -->
  <nav class="navbar">
    <div class="nav-container">
      <div class="logo">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="logo-icon"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        <span class="logo-text">Rhierro <span class="accent-text">5K</span></span>
      </div>
      <div class="nav-links">
        <button class="nav-btn active" data-target="tab-dashboard">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="9"/><rect x="14" y="3" width="7" height="5"/><rect x="14" y="12" width="7" height="9"/><rect x="3" y="16" width="7" height="5"/></svg>
          Dashboard
        </button>
        <button class="nav-btn" data-target="tab-register">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
          Registrar Productor
        </button>
        <button class="nav-btn" data-target="tab-list">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
          Productores
        </button>
      </div>
    </div>
  </nav>

  <!-- Contenido Principal -->
  <main class="main-content">
    
    <!-- ================= SECCIÓN DASHBOARD ================= -->
    <section id="tab-dashboard" class="tab-pane active">
      <div class="welcome-header">
        <h1>Sistema de Control Agropecuario</h1>
        <p class="subtitle">Administración y validación automatizada de marcas de hierros ganaderos.</p>
      </div>

      <!-- Tarjetas de Estadísticas -->
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-icon-wrapper color-green">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <div class="stat-info">
            <span class="stat-label">Productores Registrados</span>
            <h3 id="stat-producers">0</h3>
          </div>
        </div>
        
        <div class="stat-card">
          <div class="stat-icon-wrapper color-blue">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <div class="stat-info">
            <span class="stat-label">Fincas (Predios) Totales</span>
            <h3 id="stat-farms">0</h3>
          </div>
        </div>

        <div class="stat-card">
          <div class="stat-icon-wrapper color-emerald">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div class="stat-info">
            <span class="stat-label">Hierros Activos</span>
            <h3 id="stat-active-irons">0</h3>
          </div>
        </div>

        <div class="stat-card">
          <div class="stat-icon-wrapper color-purple">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
          </div>
          <div class="stat-info">
            <span class="stat-label">Estado Líder</span>
            <h3 id="stat-top-state">N/A</h3>
          </div>
        </div>
      </div>

      <!-- Sección de Acciones Rápidas -->
      <div class="dashboard-banner">
        <div class="banner-content">
          <h2>¿Listo para registrar un nuevo productor?</h2>
          <p>El sistema comprobará en tiempo real si el diseño de su hierro entra en conflicto de similitud con los ya registrados en nuestra base de datos.</p>
          <button class="btn btn-primary btn-banner-go">Iniciar Registro</button>
        </div>
        <div class="banner-ill">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="ill-svg"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
      </div>
    </section>

    <!-- ================= SECCIÓN FORMULARIO DE REGISTRO ================= -->
    <section id="tab-register" class="tab-pane">
      <div class="form-wizard-card">
        
        <!-- Indicador de Pasos -->
        <div class="wizard-steps">
          <div class="w-step active" id="w-step-1">
            <div class="step-num">1</div>
            <span class="step-text">Datos Personales</span>
          </div>
          <div class="step-line"></div>
          <div class="w-step" id="w-step-2">
            <div class="step-num">2</div>
            <span class="step-text">Fincas</span>
          </div>
          <div class="step-line"></div>
          <div class="w-step" id="w-step-3">
            <div class="step-num">3</div>
            <span class="step-text">Marca y Hierro</span>
          </div>
          <div class="step-line"></div>
          <div class="w-step" id="w-step-4">
            <div class="step-num">4</div>
            <span class="step-text">Confirmar</span>
          </div>
        </div>

        <!-- Formulario Envolvente -->
        <form id="register-form" autocomplete="off">
          
          <!-- PASO 1: DATOS PERSONALES -->
          <div class="wizard-panel active" id="panel-1">
            <div class="panel-header">
              <h2>Identificación del Productor</h2>
              <p>Ingrese la información de contacto y origen del productor agropecuario.</p>
            </div>
            
            <div class="form-grid">
              <div class="form-group">
                <label for="cedula">Cédula de Identidad / RIF *</label>
                <input type="text" id="cedula" name="cedula" placeholder="Ej: V-12345678" required>
                <small class="form-help">Formato oficial con guión (Ej: V-12345678, J-12345678-0).</small>
              </div>

              <div class="form-group">
                <label for="nombre">Nombre Completo / Razón Social *</label>
                <input type="text" id="nombre" name="nombre" placeholder="Ej: Juan Pérez" required>
              </div>

              <div class="form-group">
                <label for="telefono">Número de Teléfono *</label>
                <input type="tel" id="telefono" name="telefono" placeholder="Ej: 04141234567" required>
              </div>

              <div class="form-group">
                <label for="email">Correo Electrónico *</label>
                <input type="email" id="email" name="email" placeholder="Ej: juan.perez@correo.com" required>
              </div>

              <div class="form-group col-span-2">
                <label for="estado_id">Estado de Procedencia *</label>
                <select id="estado_id" name="estado_id" required>
                  <option value="" disabled selected>Seleccione un estado...</option>
                </select>
                <small class="form-help">Determinará el prefijo oficial en el código asignado a su hierro.</small>
              </div>
            </div>

            <div class="panel-footer">
              <div></div> <!-- Espacio para alinear a la derecha -->
              <button type="button" class="btn btn-primary btn-next" data-next="2">Siguiente Paso</button>
            </div>
          </div>

          <!-- PASO 2: DIRECCIÓN Y FINCAS -->
          <div class="wizard-panel" id="panel-2">
            <div class="panel-header">
              <h2>Fincas y Predios Asociados</h2>
              <p>Agregue una o más fincas propiedad del productor indicando su ubicación exacta.</p>
            </div>

            <!-- Fórmulas para agregar una finca -->
            <div class="finca-builder-card">
              <h3>Agregar Finca / Predio</h3>
              <div class="form-grid-3">
                <div class="form-group">
                  <label for="finca-nombre">Nombre de la Finca *</label>
                  <input type="text" id="finca-nombre" placeholder="Ej: El Hato Grande">
                </div>
                <div class="form-group">
                  <label for="finca-superficie">Superficie (Hectáreas) *</label>
                  <input type="number" id="finca-superficie" min="0.1" step="0.1" placeholder="Ej: 150.5">
                </div>
                <div class="form-group">
                  <label for="finca-municipio">Municipio *</label>
                  <select id="finca-municipio">
                    <option value="" disabled selected>Seleccione un municipio...</option>
                  </select>
                </div>
                <div class="form-group">
                  <label for="finca-parroquia">Parroquia *</label>
                  <select id="finca-parroquia">
                    <option value="" disabled selected>Seleccione una parroquia...</option>
                  </select>
                </div>
                <div class="form-group">
                  <label for="finca-sector">Sector / Caserío *</label>
                  <input type="text" id="finca-sector" placeholder="Ej: La Guamita">
                </div>
                <div class="form-group flex-align-end">
                  <button type="button" id="btn-add-finca" class="btn btn-secondary btn-full">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    Añadir Finca
                  </button>
                </div>
              </div>
            </div>

            <!-- Tabla/Listado de Fincas Agregadas -->
            <div class="added-fincas-section">
              <h3>Fincas para Registro (<span id="fincas-count">0</span> agregadas)</h3>
              <div class="table-responsive">
                <table class="data-table" id="fincas-table">
                  <thead>
                    <tr>
                      <th>Nombre</th>
                      <th>Superficie</th>
                      <th>Ubicación (Municipio, Parroquia, Sector)</th>
                      <th class="text-center">Acciones</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr class="empty-row">
                      <td colspan="4" class="text-center">No ha agregado ninguna finca aún. Complete los campos anteriores para añadir.</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>

            <div class="panel-footer">
              <button type="button" class="btn btn-outline btn-prev" data-prev="1">Atrás</button>
              <button type="button" class="btn btn-primary btn-next" data-next="3" id="btn-goto-step3">Siguiente Paso</button>
            </div>
          </div>

          <!-- PASO 3: MARCA Y HIERRO -->
          <div class="wizard-panel" id="panel-3">
            <div class="panel-header">
              <h2>Diseño de la Marca y Hierro</h2>
              <p>Registre el nombre comercial de su marca y cargue o dibuje la figura del hierro ganadero.</p>
            </div>

            <div class="form-group">
              <label for="marca_nombre">Nombre Comercial de la Marca *</label>
              <input type="text" id="marca_nombre" name="marca_nombre" placeholder="Ej: Marca La Estancia" required>
            </div>

            <div class="iron-input-container">
              
              <!-- Opción A: Subir imagen -->
              <div class="iron-input-card">
                <h3>Opción A: Subir Archivo</h3>
                <p class="card-desc">Cargue una imagen limpia con fondo blanco y líneas oscuras.</p>
                <div class="upload-dropzone" id="dropzone">
                  <input type="file" id="hierro-file-input" accept="image/png, image/jpeg, image/jpg" style="display: none;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="upload-icon"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                  <p class="dropzone-text">Arrastra tu imagen aquí o <span class="highlight">haz clic para buscar</span></p>
                  <p class="dropzone-limits">JPG, JPEG o PNG (Dimensiones: 200px a 1200px)</p>
                </div>
                <div class="preview-file-container" id="file-preview-area" style="display: none;">
                  <img id="file-preview-img" src="" alt="Vista previa del hierro cargado">
                  <button type="button" id="btn-remove-file" class="btn-remove-icon">&times;</button>
                </div>
              </div>

              <!-- Opción B: Dibujar en Lienzo -->
              <div class="iron-input-card">
                <h3>Opción B: Dibujar Hierro Digital</h3>
                <p class="card-desc">Dibuje el trazo del hierro directamente usando el mouse o pantalla táctil.</p>
                <div class="canvas-wrapper">
                  <canvas id="iron-canvas" width="300" height="300"></canvas>
                  <div class="canvas-controls">
                    <div class="brush-settings">
                      <label for="brush-size">Grosor:</label>
                      <input type="range" id="brush-size" min="4" max="16" value="8">
                    </div>
                    <button type="button" id="btn-clear-canvas" class="btn btn-outline btn-sm">Limpiar Lienzo</button>
                  </div>
                </div>
              </div>

            </div>

            <!-- Botón para iniciar el motor de similitud -->
            <div class="similarity-check-action-bar">
              <button type="button" id="btn-check-similarity" class="btn btn-secondary">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                Validar y Comprobar Similitud
              </button>
              <div id="similarity-quick-status" class="similarity-quick-status"></div>
            </div>

            <div class="panel-footer">
              <button type="button" class="btn btn-outline btn-prev" data-prev="2">Atrás</button>
              <button type="button" class="btn btn-primary btn-next" data-next="4" id="btn-goto-step4" disabled>Siguiente Paso</button>
            </div>
          </div>

          <!-- PASO 4: CONFIRMACIÓN Y REGISTRO -->
          <div class="wizard-panel" id="panel-4">
            <div class="panel-header">
              <h2>Confirmar Registro de Datos</h2>
              <p>Revise el resumen de la información que será almacenada de forma permanente en el sistema.</p>
            </div>

            <div class="summary-wrapper">
              <div class="summary-info-card">
                <h3>Datos Generales del Productor</h3>
                <div class="summary-details">
                  <div class="detail-row">
                    <span class="detail-label">Nombre:</span>
                    <strong id="sum-nombre">Juan Pérez</strong>
                  </div>
                  <div class="detail-row">
                    <span class="detail-label">Cédula / RIF:</span>
                    <strong id="sum-cedula">V-12345678</strong>
                  </div>
                  <div class="detail-row">
                    <span class="detail-label">Teléfono:</span>
                    <strong id="sum-telefono">04141234567</strong>
                  </div>
                  <div class="detail-row">
                    <span class="detail-label">Email:</span>
                    <strong id="sum-email">juan@correo.com</strong>
                  </div>
                  <div class="detail-row">
                    <span class="detail-label">Estado de Procedencia:</span>
                    <strong id="sum-estado">Zulia</strong>
                  </div>
                </div>

                <h3 class="margin-top-md">Fincas Asociadas</h3>
                <ul class="summary-fincas-list" id="sum-fincas-list">
                  <!-- Dinámico -->
                </ul>
              </div>

              <div class="summary-iron-card">
                <h3>Diseño de Hierro Validado</h3>
                <div class="summary-iron-preview">
                  <img id="sum-iron-img" src="" alt="Hierro Final">
                </div>
                <div class="summary-iron-details">
                  <div class="detail-row">
                    <span class="detail-label">Marca Comercial:</span>
                    <strong id="sum-marca-nombre">Marca El Sol</strong>
                  </div>
                  <div class="detail-row">
                    <span class="detail-label">Código de Hierro Estimado:</span>
                    <strong id="sum-hierro-codigo" class="badge badge-emerald">ZUL-01-PEND</strong>
                  </div>
                </div>
              </div>
            </div>

            <div class="panel-footer">
              <button type="button" class="btn btn-outline btn-prev" data-prev="3">Atrás</button>
              <button type="submit" class="btn btn-emerald" id="btn-submit-registration">Finalizar Registro</button>
            </div>
          </div>

        </form>
      </div>
    </section>

    <!-- ================= SECCIÓN LISTADO DE PRODUCTORES ================= -->
    <section id="tab-list" class="tab-pane">
      <div class="list-header-bar">
        <div class="welcome-header">
          <h2>Productores Agropecuarios Registrados</h2>
          <p class="subtitle">Búsqueda y consulta de expedientes de productores, fincas y marcas registradas.</p>
        </div>
        <div class="search-box-wrapper">
          <input type="text" id="search-input" placeholder="Buscar por Nombre, Cédula o Código de Hierro...">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="search-icon"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </div>
      </div>

      <!-- Tabla de Productores -->
      <div class="producers-grid" id="producers-container">
        <!-- Dinámico -->
      </div>
    </section>

  </main>

  <!-- ================= MODAL DE ADVERTENCIA DE SIMILITUD DE HIERRO ================= -->
  <div class="modal-backdrop" id="similarity-modal">
    <div class="modal-container">
      <div class="modal-header">
        <div class="modal-title-wrapper color-red">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          <h2>Diseño con Alta Similitud Detectada</h2>
        </div>
        <button class="modal-close-btn" id="btn-close-modal">&times;</button>
      </div>
      
      <div class="modal-body">
        <p class="modal-alert-desc">
          El hierro propuesto presenta una coincidencia del <strong id="modal-similarity-score" class="text-red">0%</strong> con una marca previamente registrada en el sistema (Límite máximo permitido: <span id="modal-similarity-threshold">0%</span>).
        </p>

        <!-- Selector de Hierros Similares -->
        <div class="similar-selector-container">
          <h3>Coincidencias de Hierros Similares Encontradas:</h3>
          <div class="similar-irons-list" id="modal-similar-list">
            <!-- Dinámico -->
          </div>
        </div>

        <!-- Comparador Visual Triple -->
        <div class="comparison-board">
          <div class="comp-card">
            <h4>Su Diseño</h4>
            <div class="comp-img-wrapper border-proposed">
              <img id="modal-img-proposed" src="" alt="Hierro Propuesto">
            </div>
          </div>
          
          <div class="comp-card">
            <h4>Hierro Registrado Conflictivo</h4>
            <div class="comp-img-wrapper border-conflict">
              <img id="modal-img-conflict" src="" alt="Hierro Registrado">
            </div>
            <div class="conflict-meta">
              <span class="conflict-owner" id="modal-conflict-producer">Productor: Juan Pérez</span>
              <span class="conflict-brand" id="modal-conflict-brand">Marca: La Bonanza</span>
              <span class="conflict-code" id="modal-conflict-code">Código: 22-02-ACT</span>
            </div>
          </div>

          <div class="comp-card">
            <h4>Superposición (Mapa de Coincidencias)</h4>
            <div class="comp-img-wrapper border-diff">
              <img id="modal-img-diff" src="" alt="Mapa de calor de coincidencias">
            </div>
            <div class="diff-legend">
              <span class="legend-item"><span class="legend-color bg-red"></span> Pixeles Coincidentes</span>
              <span class="legend-item"><span class="legend-color bg-green"></span> Su propuesta</span>
              <span class="legend-item"><span class="legend-color bg-grey"></span> Hierro registrado</span>
            </div>
          </div>
        </div>

        <!-- Sugerencias de Modificación -->
        <div class="suggestions-card">
          <h3>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A5.5 5.5 0 0 0 7.1 5.9C7.2 7 7.7 7.7 8.5 8.5c1 .9 1.5 2.2 1.5 3.5v1"/><path d="M9 18h6"/><path d="M10 22h4"/></svg>
            Consejos para Modificar el Diseño
          </h3>
          <ul id="modal-suggestions-list">
            <!-- Sugerencias automáticas -->
